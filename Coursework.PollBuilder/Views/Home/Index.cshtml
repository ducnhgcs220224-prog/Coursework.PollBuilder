<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="card card-vintage p-5">
            <div class="text-center mb-4">
                <h2 class="fw-bold mb-2">Create New Poll</h2>
                <p class="text-muted">Set up your question and let people vote in real-time.</p>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">Your Question</label>
                <input type="text" id="question" class="form-control form-control-vintage fs-5" placeholder="e.g., What should we have for dinner?" />
            </div>

            <label class="form-label fw-bold d-flex justify-content-between align-items-end">
                <span>Options (Max 6)</span>
                <small class="text-muted fw-normal" id="option-counter">2 / 6</small>
            </label>

            <div id="options-container">
                <div class="mb-3 position-relative">
                    <input type="text" class="form-control form-control-vintage option-input" placeholder="Option 1" />
                </div>
                <div class="mb-3 position-relative">
                    <input type="text" class="form-control form-control-vintage option-input" placeholder="Option 2" />
                </div>
            </div>

            <button type="button" class="btn btn-sm text-decoration-none fw-bold mb-4 mt-1 text-vintage-accent" onclick="addOption()">
                <i class="fa-solid fa-circle-plus me-1"></i> Add another option
            </button>

            <div class="d-grid mt-2">
                <button type="button" class="btn btn-vintage-primary btn-lg py-3 rounded-pill" onclick="createPoll()">
                    Launch Poll
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateCounter() {
            var currentOptions = $('.option-input').length;
            $('#option-counter').text(currentOptions + ' / 6');
        }

        function addOption() {
            var currentOptions = $('.option-input').length;
            if (currentOptions >= 6) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Limit Reached',
                    text: 'You can only create a maximum of 6 options!',
                    confirmButtonColor: '#5d4037'
                });
                return;
            }

            var optionNum = currentOptions + 1;
            $(`<div class="mb-3 position-relative" style="display:none;">
                <input type="text" class="form-control form-control-vintage option-input" placeholder="Option ${optionNum}" />
               </div>`).appendTo('#options-container').slideDown('fast');

            updateCounter();
        }

        function createPoll() {
            var questionText = $('#question').val();
            var optionsList = [];

            $('.option-input').each(function() {
                if ($(this).val().trim() !== "") {
                    optionsList.push($(this).val().trim());
                }
            });

            if (!questionText || optionsList.length < 2) {
                Swal.fire({
                    icon: 'error',
                    title: 'Oops...',
                    text: 'Please enter a question and at least 2 valid options!',
                    confirmButtonColor: '#5d4037'
                });
                return;
            }

            Swal.fire({
                title: 'Creating your poll...',
                allowOutsideClick: false,
                didOpen: () => {
                    Swal.showLoading();
                }
            });

            $.ajax({
                url: '/api/polls',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ question: questionText, options: optionsList }),
                success: function (response) {
                    localStorage.setItem("isCreator_" + response.code, "true");
                    window.location.href = '/poll/' + response.code;
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Something went wrong while creating the poll.',
                        confirmButtonColor: '#5d4037'
                    });
                }
            });
        }
    </script>
}